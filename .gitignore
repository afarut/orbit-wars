# ── Виртуальные окружения ───────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version

# ── Кэш и байткод Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Кэши инструментов ────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# ── Сборка / пакеты ──────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Датасеты и сырые данные (тяжёлые) ────────────────────────────────
data/
replays/
*.jsonl
*.jsonl.manifest
*.jsonl.idx.json

# ── Архивы данных ────────────────────────────────────────────────────
*.tar.zst
*.tar.gz
*.tar.xz
*.zst
*.zip

# ── Чекпоинты и веса моделей ─────────────────────────────────────────
checkpoints/
*.pt
*.pth
*.ckpt
*.safetensors

# ── Логи запусков и эксперименты ─────────────────────────────────────
outputs/          # Hydra run-директории
tb/               # TensorBoard события
runs/
lightning_logs/
wandb/
mlruns/
events.out.tfevents.*
*.log

# ── Системный / редакторский мусор ───────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

eval_runs/